const pitchShiftBuffer=(audioBuffer,context,pitchRatio)=>{
    if(Math.abs(pitchRatio-1)<0.005)return audioBuffer;
    const numChannels=audioBuffer.numberOfChannels,sampleRate=audioBuffer.sampleRate,numSamples=audioBuffer.length;
    const outputBuffer=context.createBuffer(numChannels,numSamples,sampleRate);
    for(let channel=0;channel<numChannels;channel++){
        const inputData=audioBuffer.getChannelData(channel),outputData=outputBuffer.getChannelData(channel);
        const grainSize=1024,overlap=512,hopSize=grainSize-overlap;
        const hanningWindow=new Float32Array(grainSize);
        for(let i=0;i<grainSize;i++)hanningWindow[i]=0.5*(1-Math.cos((2*Math.PI*i)/(grainSize-1)));
        const outputAccumulator=new Float32Array(numSamples+grainSize),outputWeight=new Float32Array(numSamples+grainSize);
        for(let pos=0;pos<numSamples-grainSize;pos+=hopSize){
            for(let i=0;i<grainSize;i++){
                const readIndex=Math.min(numSamples-1,Math.round(pos+i*pitchRatio));
                const val=inputData[readIndex]*hanningWindow[i];
                outputAccumulator[pos+i]+=val;
                outputWeight[pos+i]+=hanningWindow[i];
            }
        }
        for(let i=0;i<numSamples;i++){
            const w=outputWeight[i];
            outputData[i]=w>0.01?outputAccumulator[i]/w:0;
        }
    }
    return outputBuffer;
